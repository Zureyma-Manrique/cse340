<%- include('partials/header') %>
    <main class="container">
        <h1>
            <%= title %>
        </h1>
        <div class="category-list">
            <ul>
                <% categories.forEach(category=> { %>
                    <li>
                        <a href="/category/<%= category.category_id %>">
                            <%= category.name %>
                        </a>
                    </li>
                    <% }) %>
            </ul>
        </div>
    </main>
    <%- include('partials/footer') %>