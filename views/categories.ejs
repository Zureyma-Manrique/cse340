<%- include('partials/header') %>
    <main class="container">
        <h1>
            <%= title %>
        </h1>
        <div class="category-list">
            <ul>
                <% categories.forEach(category=> { %>
                    <li>
                        <a href="/category/<%= category.category_id %>">
                            <%= category.name %>
                        </a>
                        <% if (user && user.role_name==='admin' ) { %>
                            <a href="/edit-category/<%= category.category_id %>"
                                style="font-size: 0.85rem; margin-left: 0.5rem;">(edit)</a>
                            <% } %>
                    </li>
                    <% }); %>
            </ul>
        </div>

        <% if (user && user.role_name==='admin' ) { %>
            <p style="margin-top: 2rem;"><a href="/new-category">+ Add a new category</a></p>
            <% } %>
    </main>
    <%- include('partials/footer') %>