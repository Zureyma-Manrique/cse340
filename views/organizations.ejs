<%- include('partials/header') %>
    <main class="container">
        <h1>
            <%= title %>
        </h1>
        <% organizations.forEach(org=> { %>
            <div class="org-card">
                <h2>
                    <a href="/organization/<%= org.organization_id %>">
                        <%= org.name %>
                    </a>
                </h2>
                <p>
                    <%= org.description %>
                </p>
                <p>Contact: <%= org.contact_email %>
                </p>
                <img src="/images/<%= org.logo_filename %>" alt="<%= org.name %> logo" class="org-image">
            </div>
            <% }); %>

                <% if (user && user.role_name==='admin' ) { %>
                    <p style="margin-top: 2rem;"><a href="/new-organization">+ Add a new organization</a></p>
                    <% } %>
    </main>
    <%- include('partials/footer') %>