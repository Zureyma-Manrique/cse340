<%- include('partials/header') %>
    <main class="container">
        <h1>
            <%= title %>
        </h1>
        <form action="/new-project" method="POST" class="form-card">
            <div class="form-group">
                <label for="title">Project Title</label>
                <input type="text" id="title" name="title" maxlength="200" required />
            </div>
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" maxlength="1000" required></textarea>
            </div>
            <div class="form-group">
                <label for="location">Location</label>
                <input type="text" id="location" name="location" maxlength="200" required />
            </div>
            <div class="form-group">
                <label for="date">Date</label>
                <input type="date" id="date" name="date" required />
            </div>
            <div class="form-group">
                <label for="organizationId">Organization</label>
                <select id="organizationId" name="organizationId" required>
                    <option value="">-- Select an Organization --</option>
                    <% organizations.forEach(org=> { %>
                        <option value="<%= org.organization_id %>">
                            <%= org.name %>
                        </option>
                        <% }); %>
                </select>
            </div>
            <button type="submit">Create Project</button>
        </form>
        <p style="margin-top: 1.5rem;"><a href="/projects">&larr; Back to Projects</a></p>
    </main>
    <%- include('partials/footer') %>