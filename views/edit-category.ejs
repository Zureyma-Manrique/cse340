<%- include('partials/header') %>
    <main class="container">
        <h1>
            <%= title %>
        </h1>
        <form action="/edit-category/<%= category.category_id %>" method="POST">
            <div class="form-group">
                <label for="name">Category Name</label>
                <input type="text" id="name" name="name" value="<%= category.name %>" required maxlength="100">
            </div>
            <button type="submit" style="margin-top: 1rem;">Update Category</button>
        </form>
        <p style="margin-top: 1.5rem;"><a href="/category/<%= category.category_id %>">&larr; Back to Category</a></p>
    </main>
    <%- include('partials/footer') %>