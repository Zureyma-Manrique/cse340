<%- include('partials/header') %>
    <main class="container">
        <h1>
            <%= title %>
        </h1>
        <form action="/edit-organization/<%= organizationDetails.organization_id %>" method="POST" class="form-card">
            <div class="form-group">
                <label for="name">Organization Name</label>
                <input type="text" id="name" name="name" value="<%= organizationDetails.name %>" maxlength="150"
                    required />
            </div>
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" maxlength="500"
                    required><%= organizationDetails.description %></textarea>
            </div>
            <div class="form-group">
                <label for="contactEmail">Contact Email</label>
                <input type="email" id="contactEmail" name="contactEmail"
                    value="<%= organizationDetails.contact_email %>" required />
            </div>
            <input type="hidden" name="logoFilename" value="<%= organizationDetails.logo_filename %>" />
            <button type="submit">Update Organization</button>
        </form>
        <p style="margin-top: 1.5rem;"><a href="/organization/<%= organizationDetails.organization_id %>">&larr; Back to
                Organization</a></p>
    </main>
    <%- include('partials/footer') %>