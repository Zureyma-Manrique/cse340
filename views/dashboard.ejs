<%- include('partials/header') %>
<main class="container">
    <h1><%= title %></h1>

    <div class="org-card" style="max-width: 600px;">
        <h2 style="margin-bottom: 0.5rem;">Welcome, <%= name %>!</h2>
        <p style="margin-bottom: 0.5rem;"><strong>Email:</strong> <%= email %></p>
        <p><strong>Role:</strong>
            <span style="display: inline-block; background: <%= role_name === 'admin' ? '#2c3e50' : '#3498db' %>; color: #fff; padding: 0.2rem 0.7rem; border-radius: 12px; font-size: 0.85rem;">
                <%= role_name %>
            </span>
        </p>
    </div>

    <%# ── Volunteer Projects Section ── %>
    <div style="margin-top: 2rem;">
        <h2>My Volunteer Projects</h2>
        <% if (volunteerProjects && volunteerProjects.length > 0) { %>
            <div class="category-list" style="margin-top: 1rem;">
                <ul>
                    <% volunteerProjects.forEach(project => { %>
                        <li style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
                            <div>
                                <strong>
                                    <a href="/project/<%= project.project_id %>">
                                        <%= project.title %>
                                    </a>
                                </strong>
                                <span style="color: #555; font-size: 0.9rem;">
                                    &mdash; <%= project.organization_name %> &mdash;
                                    <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                </span>
                            </div>
                            <form action="/project/<%= project.project_id %>/unvolunteer?from=dashboard" method="POST">
                                <button type="submit"
                                    style="background: #e74c3c; color: #fff; border: none; padding: 0.35rem 0.8rem; border-radius: 4px; cursor: pointer; font-size: 0.85rem; font-weight: 600; white-space: nowrap;">
                                    Remove
                                </button>
                            </form>
                        </li>
                    <% }); %>
                </ul>
            </div>
        <% } else { %>
            <p style="margin-top: 0.75rem; color: #555;">
                You have not signed up to volunteer for any projects yet.
                <a href="/projects">Browse upcoming projects</a> to get involved!
            </p>
        <% } %>
    </div>

    <% if (role_name === 'admin') { %>
    <div style="margin-top: 2rem;">
        <h2>Admin Tools</h2>
        <ul style="list-style: none; padding: 0; margin-top: 1rem; display: flex; flex-direction: column; gap: 0.5rem;">
            <li><a href="/users" class="btn-link">👥 View All Registered Users</a></li>
            <li><a href="/new-organization" class="btn-link" style="margin-top: 0.5rem;">🏢 Add New Organization</a></li>
            <li><a href="/new-project" class="btn-link" style="margin-top: 0.5rem;">📋 Add New Service Project</a></li>
            <li><a href="/new-category" class="btn-link" style="margin-top: 0.5rem;">🏷️ Add New Category</a></li>
        </ul>
    </div>
    <% } %>

    <p style="margin-top: 2rem;"><a href="/logout">Sign Out</a></p>
</main>
<%- include('partials/footer') %>
